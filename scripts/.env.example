# Secrets do clear-all-cache.ps1 (cache purge: WP Rocket + Cloudways Varnish + Cloudflare).
# Projeto: Capacitaciones (hashtagcapacitaciones.com, Cloudways app sfsesufegv, server_id 1445176).
#
# COMO USAR:
#   1. Copie este arquivo para scripts\.env (mesma pasta)
#   2. Preencha os valores reais (sem aspas e sem espacos sobrando)
#   3. Pronto: o script le daqui e nao precisa mais do 1Password/biometria
#
# Resolucao dos secrets de API (Cloudways/Cloudflare):
#   variavel de ambiente do processo > este .env > 1Password (op).
#   Linha em branco/comentada -> cai pro 1Password so para aquele campo.
#
# SEGURANCA: scripts\.env tem credencial em texto plano. A pasta scripts\ ja esta excluida
#   de git (.gitignore: *.env), deploy (.deployignore) e SFTP (.vscode/sftp.json ignora
#   wp-content/themes/hashtag/scripts). Nao mova este arquivo pra fora dela.
#
# ASPAS: se um valor comecar com caractere especial (ex.: =) ou tiver espacos, ENVOLVA em
#   aspas duplas -> CHAVE="=valorQueComecaComIgual". A API Key da Cloudways comeca com '='.
#
# A conta Cloudways e a MESMA do hashtag (o app e achado pelo sys_user `sfsesufegv`),
# entao CLOUDWAYS_EMAIL/CLOUDWAYS_API_KEY sao os mesmos. O CLOUDFLARE_TOKEN precisa de
# permissao na zona `hashtagcapacitaciones.com` (o token do hashtag cobre so a zona dele).

# E-mail de login da conta Cloudways
CLOUDWAYS_EMAIL=

# Cloudways API Key (Console -> Account -> API Key) -- comeca com '=', use aspas
CLOUDWAYS_API_KEY=

# Cloudflare API Token da zona hashtagcapacitaciones.com
#   (perm.: Zone Settings:Edit + Zone:Read + Zone WAF:Edit + Cache Purge)
CLOUDFLARE_TOKEN=

# ---------------------------------------------------------------------------
# Bing Webmaster Tools (scripts/bing-submit.ps1) -- SECRETA, da propriedade Cap no BWT.
# NAO confundir com a chave PUBLICA do IndexNow (<chave>.txt na raiz).
# ---------------------------------------------------------------------------
BWT_API_KEY=

# ---------------------------------------------------------------------------
# Google Search Console (scripts/gsc/gsc.py): service account com permissao na
# propriedade GSC da Cap. JSON em scripts/gsc/ (gitignored). Setup: ver hashtag.
# ---------------------------------------------------------------------------
GSC_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY=

# ---------------------------------------------------------------------------
# Mailer transacional (mu-plugin hashtag-mailer.php) -- App Password do Gmail/Workspace.
# A senha NAO vai no DB; o mailer le do wp-config (constante HASHTAG_SMTP_PASS).
# Guardar aqui so como referencia/backup; o runtime usa o wp-config de prod.
# ---------------------------------------------------------------------------
HASHTAG_SMTP_PASS=
